# chatbot-service environment configuration
# Copy this file to .env and fill in real values.

APP_NAME=chatbot-service
ENVIRONMENT=dev

DATABASE_URL=postgresql+psycopg2://survivor:survivor-pw@localhost:5432/survivor
GRAPH_CORE_BASE_URL=http://graph-core:8080
ATTACHMENT_STORAGE_PATH=/tmp/chatbot-attachments

# --- LLM ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
LLM_ENABLED=true
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.3
