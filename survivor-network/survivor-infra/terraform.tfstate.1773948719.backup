            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "failed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "image:\n  tag: latest\nauth:\n  existingSecret: minio-auth\ndefaultBuckets:\n  - survivor-evidence\n  - ai-artifacts\nnodeSelector:\n  tier: data\ntolerations:\n  - key: tier\n    value: data\n    effect: NoSchedule\nprimary:\n  resources:\n    requests:\n      memory: 512Mi\n    limits:\n      memory: 1Gi\n      cpu: 500m\nconsole:\n  enabled: true\n"
