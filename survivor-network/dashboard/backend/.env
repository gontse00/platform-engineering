# Database (Internal K8s DNS)
DB_HOST=survivor-db-postgresql.data.svc.cluster.local
DB_PORT=5432
DB_NAME=survivor
DB_USER=survivor
DB_PASS=survivor-pw

# Storage (Internal K8s DNS)
MINIO_ENDPOINT=survivor-storage.data.svc.cluster.local:9000
MINIO_ACCESS_KEY=survivor-admin
MINIO_SECRET_KEY=survivor-storage-pw
MINIO_SECURE=false

# AI Configuration (Using Gemini API for the "Brain")
GOOGLE_API_KEY="API KEY HERE"